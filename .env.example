# ── Server (safe to set on Railway — public values only) ─────────────────────
PORT=4021
NODE_ENV=development

# Receiving wallet (public address only — NEVER put private keys on the server)
# EVM: 0x…   Solana: base58 pubkey
PAY_TO_ADDRESS=0xYourReceivingAddress

# Optional explicit receivers when enabling both EVM and Solana networks
# PAY_TO_EVM_ADDRESS=0xYourEvmAddress
# PAY_TO_SVM_ADDRESS=YourSolanaBase58Address

# Price in USD for paid endpoints (must be between 0.01 and 0.10)
PRICE_USD=0.01
# IV surface endpoint (typically higher than single-option)
PRICE_VOL_SURFACE_USD=0.10
# Max options per surface request (1–500, default 200)
MAX_SURFACE_OPTIONS=200

# Comma-separated networks:
#   base-sepolia | base | solana | solana-devnet
# Aliases also accepted: solana-mainnet, "solana mainnet" → solana
#
# Defaults:
#   base-sepolia  → works with https://x402.org/facilitator
#   solana        → Solana mainnet (CAIP-2 solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp)
#                   use PayAI or CDP facilitator (x402.org is testnet-only)
NETWORKS=base-sepolia

# Facilitator URL — must support every network in NETWORKS
# Testnet (public):  https://x402.org/facilitator          (Base Sepolia, Solana Devnet)
# Multi mainnet:     https://facilitator.payai.network     (Base + Solana, no API keys)
# CDP production:    https://api.cdp.coinbase.com/platform/v2/x402
FACILITATOR_URL=https://x402.org/facilitator

# Optional: CDP credentials if using the CDP facilitator (set only in Railway secrets)
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Public base URL of this service (service card / discovery). Set to your Railway URL.
PUBLIC_BASE_URL=http://localhost:4021

# CORS origins (comma-separated). Use * only for local dev; set your domain in prod.
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Idempotency cache TTL (milliseconds)
IDEMPOTENCY_TTL_MS=300000

# Set to 1 when running behind a reverse proxy (Railway, nginx, Caddy, load balancer)
TRUST_PROXY=0

# Local/debug ONLY: skip x402 payment gate so handlers return 200 JSON without USDC.
# Rejected when NODE_ENV=production. Never set on Railway.
# SKIP_PAYMENT=1

# ── Railway production example (Variables tab — no secrets for buyer keys) ───
# NODE_ENV=production
# TRUST_PROXY=1
# PAY_TO_ADDRESS=YourPublicReceivingAddress
# NETWORKS=solana
# PRICE_USD=0.01
# FACILITATOR_URL=https://facilitator.payai.network
# PUBLIC_BASE_URL=https://your-service.up.railway.app
# CORS_ORIGIN=https://your-frontend.example.com
# (PORT is injected by Railway — do not hardcode)

# ── Client only (local machine — NEVER set on Railway) ───────────────────────
# Never commit real keys. Fund buyer wallet with USDC on the target network.
# EVM_PRIVATE_KEY=0x...
# SVM_PRIVATE_KEY=...
# SERVER_URL=http://localhost:4021

